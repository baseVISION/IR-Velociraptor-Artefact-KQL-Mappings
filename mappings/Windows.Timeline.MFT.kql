//ARTIFACT: Windows.Timeline.MFT
.create table WindowsTimelineMFT (
    Timestamp: datetime,
    Hostname: string,
    Path: string,
    Message: string,
    IsDir: bool,
    InUse: bool,
    FileSize: long,
    FNCreatedShift: bool,
    USecZero: bool,
    PossibleCopy: bool,
    VolumeCopy: bool,
    SI_Created: datetime,
    SI_LastModified: datetime,
    SI_LastAccess: datetime,
    SI_LastRecordChange: datetime,
    FN_Created: datetime,
    FN_LastModified: datetime,
    FN_LastAccess: datetime,
    FN_LastRecordChange: datetime,
    EntryNumber: long,
    ParentEntryNumber: long,
    EventTime: datetime,
    Parser: string,
    Source: string,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
)

.create-or-alter function RouteWindowsTimelineMFT() {
    RawVelociraptorEvents
    | where Artifact == "Windows.Timeline.MFT"
    | extend 
        EventTime = todatetime(RawData.event_time),
        Path = tostring(RawData.path),
        Message = tostring(RawData.message),
        IsDir = tobool(RawData.optional_1.IsDir),
        InUse = tobool(RawData.optional_1.InUse),
        FileSize = tolong(RawData.optional_1.FileSize),
        FNCreatedShift = tobool(RawData.optional_2.FNCreatedShift),
        USecZero = tobool(RawData.optional_2.USecZero),
        PossibleCopy = tobool(RawData.optional_2.PossibleCopy),
        VolumeCopy = tobool(RawData.optional_2.VolumeCopy),
        SI_Created = todatetime(RawData.optional_3.Created0x10),
        SI_LastModified = todatetime(RawData.optional_3.LastModified0x10),
        SI_LastAccess = todatetime(RawData.optional_3.LastAccess0x10),
        SI_LastRecordChange = todatetime(RawData.optional_3.LastRecordChange0x10),
        FN_Created = todatetime(RawData.optional_4.Created0x30),
        FN_LastModified = todatetime(RawData.optional_4.LastModified0x30),
        FN_LastAccess = todatetime(RawData.optional_4.LastAccess0x30),
        FN_LastRecordChange = todatetime(RawData.optional_4.LastRecordChange0x30),
        EntryNumber = tolong(RawData.optional_1.EntryNumber),
        ParentEntryNumber = tolong(RawData.optional_1.ParentEntryNumber),
        Parser = tostring(RawData.parser),
        Source = tostring(RawData.source)
    | extend Timestamp = case(
        Message has "0x10" and Message has "Created",          SI_Created,
        Message has "0x10" and Message has "LastModified",     SI_LastModified,
        Message has "0x10" and Message has "LastAccess",       SI_LastAccess,
        Message has "0x10" and Message has "LastRecordChange", SI_LastRecordChange,
        Message has "0x30" and Message has "Created",          FN_Created,
        Message has "0x30" and Message has "LastModified",     FN_LastModified,
        Message has "0x30" and Message has "LastAccess",       FN_LastAccess,
        Message has "0x30" and Message has "LastRecordChange", FN_LastRecordChange,
        EventTime
    )
    | project 
        Timestamp,
        Hostname,
        Path,
        Message,
        IsDir,
        InUse,
        FileSize,
        FNCreatedShift,
        USecZero,
        PossibleCopy,
        VolumeCopy,
        SI_Created,
        SI_LastModified,
        SI_LastAccess,
        SI_LastRecordChange,
        FN_Created,
        FN_LastModified,
        FN_LastAccess,
        FN_LastRecordChange,
        EntryNumber,
        ParentEntryNumber,
        EventTime,
        Parser,
        Source,
        Artifact,
        Organization,
        ClientId,
        FlowId,
        IngestionTime
}

.alter table WindowsTimelineMFT policy update @'[{"IsEnabled":true,"Source":"RawVelociraptorEvents","Query":"RouteWindowsTimelineMFT()","IsTransactional":false}]'
