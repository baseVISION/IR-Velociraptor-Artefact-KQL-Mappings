//ARTIFACT: DetectRaptor.Windows.Detection.LolRMM
.create table DetectRaptorWindowsDetectionLolRMM (
    Timestamp: datetime,
    Hostname: string,
    Name: string,
    Description: string,
    EventDisplayName: string,
    EventPublisher: string,
    EventDisplayVersion: string,
    EventInstallLocation: string,
    EventInstallDate: string,
    EventInstallSource: string,
    EventUninstallString: string,
    Source: string,
    HitPathRegex: string,
    HitDomainRegex: string,
    LolRMMLink: string,
    HitRegex: dynamic,
    Event: dynamic,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
)

.create-or-alter function RouteDetectRaptorWindowsDetectionLolRMM() {
    RawVelociraptorEvents
    | where Artifact == "DetectRaptor.Windows.Detection.LolRMM"
    | extend 
        Name = tostring(RawData.Name),
        Description = tostring(RawData.Description),
        Source = tostring(RawData.Source),
        LolRMMLink = tostring(RawData.LolRMMLink),
        HitPathRegex = tostring(RawData.HitRegex.PathRegex),
        HitDomainRegex = tostring(RawData.HitRegex.DomainRegex),
        EventDisplayName = tostring(RawData.Event.DisplayName),
        EventDisplayVersion = tostring(RawData.Event.DisplayVersion),
        EventPublisher = tostring(RawData.Event.Publisher),
        EventInstallLocation = tostring(RawData.Event.InstallLocation),
        EventInstallSource = tostring(RawData.Event.InstallSource),
        EventInstallDate = tostring(RawData.Event.InstallDate),
        EventUninstallString = tostring(RawData.Event.UninstallString),
        HitRegex = RawData.HitRegex,
        Event = RawData.Event
    | project 
        Timestamp, 
        Hostname, 
        Name,
        Description,
        EventDisplayName,
        EventPublisher,
        EventDisplayVersion,
        EventInstallLocation,
        EventInstallDate,
        EventInstallSource,
        EventUninstallString,
        Source,
        HitPathRegex,
        HitDomainRegex,
        LolRMMLink,
        HitRegex,
        Event,
        Artifact,
        Organization,
        ClientId,
        FlowId,
        IngestionTime
}

.alter table DetectRaptorWindowsDetectionLolRMM policy update @'[{"Source": "RawVelociraptorEvents", "Query": "RouteDetectRaptorWindowsDetectionLolRMM()", "IsEnabled": "True", "IsTransactional": true}]'
