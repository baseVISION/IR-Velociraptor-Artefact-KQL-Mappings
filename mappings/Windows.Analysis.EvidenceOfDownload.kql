//ARTIFACT: Windows.Analysis.EvidenceOfDownload
.create table WindowsAnalysisEvidenceOfDownload (
    Timestamp: datetime,
    Hostname: string,
    DownloadedFilePath: string,
    Mtime: datetime,
    ZoneId: string,
    HostUrl: string,
    ReferrerUrl: string,
    ZoneIdentifierContent: string,
    FileHashMD5: string,
    FileHashSHA1: string,
    FileHashSHA256: string,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
)

.create-or-alter function RouteWindowsAnalysisEvidenceOfDownload() {
    RawVelociraptorEvents
    | where Artifact == "Windows.Analysis.EvidenceOfDownload"
    | extend 
        DownloadedFilePath = tostring(RawData.DownloadedFilePath),
        Mtime = todatetime(RawData.Mtime),
        ZoneId = tostring(RawData.ZoneId),
        HostUrl = tostring(RawData.HostUrl),
        ReferrerUrl = tostring(RawData.ReferrerUrl),
        ZoneIdentifierContent = tostring(RawData._ZoneIdentifierContent),
        FileHashMD5 = tostring(RawData.FileHash.MD5),
        FileHashSHA1 = tostring(RawData.FileHash.SHA1),
        FileHashSHA256 = tostring(RawData.FileHash.SHA256)
    | project 
        Timestamp, 
        Hostname, 
        DownloadedFilePath,
        Mtime,
        ZoneId,
        HostUrl,
        ReferrerUrl,
        ZoneIdentifierContent,
        FileHashMD5,
        FileHashSHA1,
        FileHashSHA256,
        Artifact,
        Organization,
        ClientId, 
        FlowId, 
        IngestionTime
}

.alter table WindowsAnalysisEvidenceOfDownload policy update @'[{"IsEnabled":true,"Source":"RawVelociraptorEvents","Query":"RouteWindowsAnalysisEvidenceOfDownload()","IsTransactional":false}]'
