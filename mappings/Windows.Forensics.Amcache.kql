// NOTE: verified against the upstream Velociraptor artifact definition that this artifact is
// actually named "Windows.Forensics.Amcache" (not "Windows.System.Amcache" - that name does not
// exist upstream). The table/function below were previously misnamed and filtered on a
// non-existent artifact name, so they never received any data. If a deployment previously
// created the old objects, clean them up with:
//   .drop table WindowsSystemAmcacheInventoryApplicationFile ifexists
//   .drop function RouteWindowsSystemAmcacheInventoryApplicationFile ifexists
//ARTIFACT: Windows.Forensics.Amcache/InventoryApplicationFile
.create table WindowsForensicsAmcacheInventoryApplicationFile (
    Timestamp: datetime,
    Hostname: string,
    Name: string,
    FullPath: string,
    OriginalFileName: string,
    ProductName: string,
    ProductVersion: string,
    AppxPackageFullName: string,
    SHA1: string,
    Size: long,
    BinaryType: string,
    LinkDate: string,
    Usn: long,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
)

.create-or-alter function RouteWindowsForensicsAmcacheInventoryApplicationFile() {
    RawVelociraptorEvents
    | where Artifact == "Windows.Forensics.Amcache/InventoryApplicationFile"
    | extend 
        Name = tostring(RawData.Name),
        FullPath = tostring(RawData.FullPath),
        OriginalFileName = tostring(RawData.OriginalFileName),
        ProductName = tostring(RawData.ProductName),
        ProductVersion = tostring(RawData.ProductVersion),
        AppxPackageFullName = tostring(RawData.AppxPackageFullName),
        SHA1 = tostring(RawData.SHA1),
        Size = tolong(RawData.Size),
        BinaryType = tostring(RawData.BinaryType),
        LinkDate = tostring(RawData.LinkDate),
        Usn = tolong(RawData.Usn)
    | extend Timestamp = todatetime(RawData.Timestamp)
    | project 
        Timestamp, 
        Hostname, 
        Name,
        FullPath,
        OriginalFileName,
        ProductName,
        ProductVersion,
        AppxPackageFullName,
        SHA1,
        Size,
        BinaryType,
        LinkDate,
        Usn,
        Artifact,
        Organization,
        ClientId,
        FlowId,
        IngestionTime
}

.alter table WindowsForensicsAmcacheInventoryApplicationFile policy update @'[{"Source": "RawVelociraptorEvents", "Query": "RouteWindowsForensicsAmcacheInventoryApplicationFile()", "IsEnabled": "True", "IsTransactional": true}]'

