.alter table WindowsForensicsAmcacheInventoryDriverBinary policy update @'[{"Source": "RawVelociraptorEvents", "Query": "RouteWindowsForensicsAmcacheInventoryDriverBinary()", "IsEnabled": "True", "IsTransactional": true}]'

