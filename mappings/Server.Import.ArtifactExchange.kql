//ARTIFACT: Server.Import.ArtifactExchange
.create table ServerImportArtifactExchange (
    Timestamp: datetime,
    Hostname: string,
    ArtifactName: string,
    Description: string,
    Author: string,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
)

.create-or-alter function RouteServerImportArtifactExchange() {
    RawVelociraptorEvents
    | where Artifact == "Server.Import.ArtifactExchange"
    | extend 
        ArtifactName = tostring(RawData.Name),
        Description = tostring(RawData.Description),
        Author = tostring(RawData.Author)
    | project 
        Timestamp, 
        Hostname, 
        ArtifactName,
        Description,
        Author,
        Artifact,
        Organization,
        ClientId, 
        FlowId, 
        IngestionTime
}

.alter table ServerImportArtifactExchange policy update @'[{"IsEnabled":true,"Source":"RawVelociraptorEvents","Query":"RouteServerImportArtifactExchange()","IsTransactional":false}]'
