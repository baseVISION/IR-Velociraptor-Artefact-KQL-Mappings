//ARTIFACT: Generic.System.EfiSignatures/Certificates
.create table GenericSystemEfiSignaturesCertificates (
    Timestamp: datetime,
    Hostname: string,
    Name: string,
    Owner: string,
    SerialNumber: string,
    Subject: string,
    Issuer: string,
    NotBefore: datetime,
    NotAfter: datetime,
    SignatureAlgorithm: string,
    PublicKey: string,
    Extensions: dynamic,
    Certificate: dynamic,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
)

.create-or-alter function RouteGenericSystemEfiSignaturesCertificates() {
    RawVelociraptorEvents
    | where Artifact == "Generic.System.EfiSignatures/Certificates"
    | extend 
        Name = tostring(RawData.Name),
        Owner = tostring(RawData.Owner),
        SerialNumber = tostring(RawData.Certificate.SerialNumber),
        Subject = tostring(RawData.Certificate.Subject),
        Issuer = tostring(RawData.Certificate.Issuer),
        NotBefore = todatetime(RawData.Certificate.NotBefore),
        NotAfter = todatetime(RawData.Certificate.NotAfter),
        SignatureAlgorithm = tostring(RawData.Certificate.SignatureAlgorithm),
        PublicKey = tostring(RawData.Certificate.PublicKey),
        Extensions = RawData.Certificate.Extensions,
        Certificate = RawData.Certificate
    | project 
        Timestamp, 
        Hostname, 
        Name,
        Owner,
        SerialNumber,
        Subject,
        Issuer,
        NotBefore,
        NotAfter,
        SignatureAlgorithm,
        PublicKey,
        Extensions,
        Certificate,
        Artifact,
        Organization,
        ClientId, 
        FlowId, 
        IngestionTime
}

.alter table GenericSystemEfiSignaturesCertificates policy update @'[{"IsEnabled":true,"Source":"RawVelociraptorEvents","Query":"RouteGenericSystemEfiSignaturesCertificates()","IsTransactional":false}]'

//ARTIFACT: Generic.System.EfiSignatures/Hashes
.create table GenericSystemEfiSignaturesHashes (
    Timestamp: datetime,
    Hostname: string,
    Name: string,
    Owner: string,
    Hash: string,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
)

.create-or-alter function RouteGenericSystemEfiSignaturesHashes() {
    RawVelociraptorEvents
    | where Artifact == "Generic.System.EfiSignatures/Hashes"
    | extend 
        Name = tostring(RawData.Name),
        Owner = tostring(RawData.Owner),
        Hash = tostring(RawData.Hash)
    | project 
        Timestamp, 
        Hostname, 
        Name,
        Owner,
        Hash,
        Artifact,
        Organization,
        ClientId, 
        FlowId, 
        IngestionTime
}

.alter table GenericSystemEfiSignaturesHashes policy update @'[{"IsEnabled":true,"Source":"RawVelociraptorEvents","Query":"RouteGenericSystemEfiSignaturesHashes()","IsTransactional":false}]'
