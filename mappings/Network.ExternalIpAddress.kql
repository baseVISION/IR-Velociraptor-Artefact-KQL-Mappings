//ARTIFACT: Network.ExternalIpAddress
.create table NetworkExternalIpAddress (
    Timestamp: datetime,
    Hostname: string,
    IP: string,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
)

.create-or-alter function RouteNetworkExternalIpAddress() {
    RawVelociraptorEvents
    | where Artifact == "Network.ExternalIpAddress"
    | extend 
        IP = tostring(RawData.IP)
    | project 
        Timestamp, 
        Hostname, 
        IP,
        Artifact,
        Organization,
        ClientId, 
        FlowId, 
        IngestionTime
}

.alter table NetworkExternalIpAddress policy update @'[{"IsEnabled":true,"Source":"RawVelociraptorEvents","Query":"RouteNetworkExternalIpAddress()","IsTransactional":false}]'
