    // ========================================================================
    // [FileSystem] WindowsTimelineMFT — MFT timeline (already timeline-formatted)
    let _timelineMft =
        WindowsTimelineMFT
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "FileSystem" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "MFTTimeline" in (_fTypeList)
        | extend _flags = strcat_array(
            array_concat(
                iff(FNCreatedShift, dynamic(["FNCreatedShift"]), dynamic([])),
                iff(USecZero,       dynamic(["USecZero"]),       dynamic([])),
                iff(PossibleCopy,   dynamic(["PossibleCopy"]),   dynamic([])),
                iff(VolumeCopy,     dynamic(["VolumeCopy"]),     dynamic([]))
            ), ", ")
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "FileSystem",
            EventType      = "MFTTimeline",
            Description    = strcat("[", Source, "] ", Message, " | ", Path,
                              " | Size: ", tostring(FileSize),
                              iff(_flags == "", "", strcat(" | Flags: ", _flags))),
            User           = "",
            Path,
            Hash           = "",
            Details        = bag_pack(
                                "EntryNumber", EntryNumber,
                                "ParentEntryNumber", ParentEntryNumber,
                                "IsDir", IsDir,
                                "InUse", InUse,
                                "SI_Created", SI_Created,
                                "SI_LastModified", SI_LastModified,
                                "SI_LastAccess", SI_LastAccess,
                                "SI_LastRecordChange", SI_LastRecordChange,
