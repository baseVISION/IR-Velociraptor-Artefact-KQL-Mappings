// ============================================
// Source: analysis/Windows.Persistence.Overview.kql
// ============================================

//ARTIFACT: Windows.Persistence.Overview
// Windows Persistence Overview — unions all persistence-related snapshot tables
// into a single normalized view for rapid identification of persistence mechanisms.
//
// Sources (8 tables):
//   Autoruns         — Sysinternals Autoruns (Category used as PersistenceType)
//   ScheduledTask    — Registry-parsed scheduled tasks (Mtime timestamp)
//   StartupItem      — Startup folder/registry items (deduplicated from 2 artifacts)
//   WMISubscription  — WMI event filter/consumer bindings
//   WMIProvider      — Registered WMI providers
//   LocalAccount     — SAM-parsed local user accounts (CreatedTime, LastLoginDate)
//   LocalAdmin       — Local Administrators group members
//
// Usage:
//   WindowsPersistenceOverview("DESKTOP-ABC")
//   WindowsPersistenceOverview("DESKTOP-ABC", filterType="ScheduledTask")
//   WindowsPersistenceOverview("DESKTOP-ABC", filterType="LocalAccount,LocalAdmin")
//   WindowsPersistenceOverview("", targetOrg="CaseOrg1")

.create-or-alter function with (folder="Analysis", docstring="Windows persistence overview — unions all persistence snapshot tables into a single view for rapid triage.", skipvalidation="true")
WindowsPersistenceOverview(
    targetHostname:string,
    targetOrg:string = "",
    filterType:string = ""
) {
    let _host = targetHostname;
    let _org  = targetOrg;
    let _fTypeList = iff(filterType == "", dynamic([]), split(filterType, ","));
    // ========================================================================
    // Autoruns (Sysinternals) — PersistenceType = Category (Logon, Services, etc.)
    // ========================================================================
    let _autoruns =
        WindowsSysinternalsAutoruns
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fTypeList) == 0 or Category in (_fTypeList)
        | project
            PersistenceType = Category,
            Name            = Entry,
            Target          = coalesce(ImagePath, LaunchString, ""),
            EntryLocation,
            User            = "",
            Enabled         = iff(Enabled == "enabled", "enabled", "disabled"),
            Signer          = coalesce(Signer, ""),
            Hash            = coalesce(SHA256, SHA1, MD5, ""),
            LastModified    = Timestamp,
            Details         = bag_pack(
                                "Description", Description,
                                "Company", Company,
                                "Version", Version,
                                "Profile", Profile,
                                "LaunchString", LaunchString,
                                "MD5", MD5,
                                "SHA1", SHA1,
                                "SHA256", SHA256,
                                "PESHA1", PESHA1,
                                "PESHA256", PESHA256,
                                "IMP", IMP
                            ),
            SourceArtifact  = Artifact,
            Hostname,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // Scheduled Tasks (Registry) — PersistenceType = "ScheduledTask"
    // ========================================================================
    let _scheduledTasks =
        WindowsRegistryScheduledTasks
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fTypeList) == 0 or "ScheduledTask" in (_fTypeList)
        | project
            PersistenceType = "ScheduledTask",
            Name            = URI,
            Target          = strcat(coalesce(Command, ""), iff(Arguments == "", "", strcat(" ", Arguments))),
            EntryLocation   = Path,
            User            = coalesce(UserId, ""),
            Enabled         = "",
            Signer          = "",
            Hash            = coalesce(Hash, ""),
            LastModified    = Mtime,
            Details         = bag_pack(
                                "TaskID", TaskID,
                                "Description", Description,
                                "Author", Author,
                                "ComHandler", ComHandler,
                                "Triggers", Triggers,
                                "Actions", Actions,
                                "Date", Date,
                                "SecurityDescriptor", SecurityDescriptor,
                                "DynamicInfo", DynamicInfo
                            ),
            SourceArtifact  = Artifact,
            Hostname,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // Startup Items — PersistenceType = "StartupItem"
    // Deduplicated from Windows.Packs.Persistence and Windows.Sys.StartupItems
    // ========================================================================
    let _startupItems =
        union
            (WindowsPacksPersistenceStartupItems
            | where isempty(_host) or Hostname has _host
            | where isempty(_org) or Organization == _org
            | project Hostname, Name, OSPath, ItemDetails = Details, Enabled, Source, Artifact, Organization, ClientId, FlowId, IngestionTime),
            (WindowsSysStartupItems
            | where isempty(_host) or Hostname has _host
            | where isempty(_org) or Organization == _org
            | project Hostname, Name, OSPath, ItemDetails = Details, Enabled, Source = "", Artifact, Organization, ClientId, FlowId, IngestionTime)
        | summarize arg_max(IngestionTime, *) by Hostname, Name, ItemDetails
        | where array_length(_fTypeList) == 0 or "StartupItem" in (_fTypeList)
        | project
            PersistenceType = "StartupItem",
            Name,
            Target          = coalesce(ItemDetails, ""),
            EntryLocation   = coalesce(OSPath, ""),
            User            = "",
            Enabled         = iff(Enabled == "enabled", "enabled", "disabled"),
            Signer          = "",
            Hash            = "",
            LastModified    = datetime(null),
            Details         = bag_pack(
                                "Source", Source
                            ),
            SourceArtifact  = Artifact,
            Hostname,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // WMI Event Subscriptions — PersistenceType = "WMISubscription"
    // ========================================================================
    let _wmiSubscriptions =
        WindowsPacksPersistenceWMIEventFilters
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fTypeList) == 0 or "WMISubscription" in (_fTypeList)
        | project
            PersistenceType = "WMISubscription",
            Name            = coalesce(ConsumerName, FilterName, ""),
            Target          = coalesce(FilterQuery, ""),
            EntryLocation   = coalesce(Namespace, ""),
            User            = "",
            Enabled         = "",
            Signer          = "",
            Hash            = "",
            LastModified    = datetime(null),
            Details         = bag_pack(
                                "ConsumerName", ConsumerName,
                                "ConsumerSourceName", ConsumerSourceName,
                                "ConsumerCategory", ConsumerCategory,
                                "FilterName", FilterName,
                                "FilterEventNamespace", FilterEventNamespace,
                                "FilterQueryLanguage", FilterQueryLanguage,
                                "ConsumerDetails", ConsumerDetails,
                                "FilterDetails", FilterDetails
                            ),
            SourceArtifact  = Artifact,
            Hostname,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // WMI Providers — PersistenceType = "WMIProvider"
    // ========================================================================
    let _wmiProviders =
        WindowsSystemWMIProviders
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fTypeList) == 0 or "WMIProvider" in (_fTypeList)
        | project
            PersistenceType = "WMIProvider",
            Name,
            Target          = coalesce(BinaryPath, ""),
            EntryLocation   = coalesce(CLSID, ""),
            User            = "",
            Enabled         = "",
            Signer          = "",
            Hash            = "",
            LastModified    = datetime(null),
            Details         = bag_pack(
                                "ServerType", ServerType,
                                "CLSID", CLSID
                            ),
            SourceArtifact  = Artifact,
            Hostname,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // Local Accounts (SAM Parsed) — PersistenceType = "LocalAccount"
    // ========================================================================
    let _localAccounts =
        WindowsForensicsSAMParsed
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fTypeList) == 0 or "LocalAccount" in (_fTypeList)
        | lookup (WindowsForensicsSAMCreateTimes | project Hostname, Username, CreatedTime) on Hostname, Username
        | project
            PersistenceType = "LocalAccount",
            Name            = Username,
            Target          = coalesce(ProfilePath, LogonScript, ""),
            EntryLocation   = coalesce(Key, ""),
            User            = Username,
            Enabled         = iff(tostring(Flags) has "AccountDisabled", "disabled", "enabled"),
            Signer          = "",
            Hash            = coalesce(NtpwdHash, ""),
            LastModified    = coalesce(CreatedTime, LastLoginDate, PasswordResetDate),
            Details         = bag_pack(
                                "RID", RID,
                                "Fullname", Fullname,
                                "Comment", Comment,
                                "AccountType", AccountType,
                                "CreatedTime", CreatedTime,
                                "LoginCount", LoginCount,
                                "FailedLoginCount", FailedLoginCount,
                                "LastLoginDate", LastLoginDate,
                                "PasswordResetDate", PasswordResetDate,
                                "PasswordFailDate", PasswordFailDate,
                                "Flags", Flags,
                                "LmpwdHash", LmpwdHash,
                                "NtpwdHash", NtpwdHash
                            ),
            SourceArtifact  = Artifact,
            Hostname,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // Local Administrators — PersistenceType = "LocalAdmin"
    // ========================================================================
    let _localAdmins =
        WindowsSystemLocalAdmins
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fTypeList) == 0 or "LocalAdmin" in (_fTypeList)
        | project
            PersistenceType = "LocalAdmin",
            Name,
            Target          = "",
            EntryLocation   = coalesce(SID, ""),
            User            = Name,
            Enabled         = "",
            Signer          = "",
            Hash            = "",
            LastModified    = datetime(null),
            Details         = bag_pack(
                                "SID", SID,
                                "PrincipalSource", PrincipalSource
                            ),
            SourceArtifact  = Artifact,
            Hostname,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // Union all persistence sources
    // ========================================================================
    union
        _autoruns,
        _scheduledTasks,
        _startupItems,
        _wmiSubscriptions,
        _wmiProviders,
        _localAccounts,
        _localAdmins
    // ====================================================================
    // Suspicion flags — each flag is an independent dynamic array append.
    // To add a new flag: copy any block below, change the condition and label.
    // Flags only apply to "real" entries (enabled, or disabled with a Name/Target).
    // ====================================================================
    | extend _isRealEntry = not(Enabled == "disabled" and Name == "" and Target == "")
    | extend _flags = dynamic([])
    // -- Unsigned: Autoruns entry with missing or unverified signature (skip empty placeholders)
    | extend _flags = iff(_isRealEntry
        and SourceArtifact has "Autoruns"
        and (Signer == "" or Signer has "Not verified"),
        array_concat(_flags, dynamic(["Unsigned"])), _flags)
    // -- NoMetadata: Autoruns entry with no Description and no Company (skip empty placeholders)
    | extend _flags = iff(_isRealEntry
        and SourceArtifact has "Autoruns"
        and tostring(Details.Description) == ""
        and tostring(Details.Company) == "",
        array_concat(_flags, dynamic(["NoMetadata"])), _flags)
    // -- SuspiciousPath: Target points to a writable / user-controlled location
    | extend _flags = iff(Target contains @"\Temp\"
        or Target contains @"\AppData\"
        or Target contains @"\Public\"
        or Target contains @"\Downloads\",
        array_concat(_flags, dynamic(["SuspiciousPath"])), _flags)
    // -- EncodedCommand: PowerShell with encoded command argument
    | extend _flags = iff(Target has "powershell"
        and Target matches regex @".*\s\-e(nc|ncode|ncodedcommand)?\s.*",
        array_concat(_flags, dynamic(["EncodedCommand"])), _flags)
    // -- LOLBin: Target references a Living-off-the-Land binary
    | extend _flags = iff(Target has_any (
            "certutil", "rundll32", "regsvr32", "mshta", "bitsadmin",
            "msiexec", "wmic", "cmstp", "installutil", "forfiles",
            "pcalua", "wscript", "cscript"),
        array_concat(_flags, dynamic(["LOLBin"])), _flags)
    // -- WMISubscription: WMI event subscriptions, excluding known Windows defaults
    | extend _flags = iff(PersistenceType == "WMISubscription"
        and not(Name in ("SCM Event Log Consumer", "BVTConsumer")),
        array_concat(_flags, dynamic(["WMISubscription"])), _flags)
    // -- NonStandardTask: scheduled task outside \Microsoft\Windows\ tree
    | extend _flags = iff(PersistenceType == "ScheduledTask"
        and not(Name startswith @"\Microsoft\Windows\"),
        array_concat(_flags, dynamic(["NonStandardTask"])), _flags)
    // -- ElevatedUserPath: task runs as SYSTEM but target is in user-writable path
    | extend _flags = iff(PersistenceType == "ScheduledTask"
        and (User == "SYSTEM" or User == "LocalSystem" or User == "S-1-5-18")
        and (Target contains @"\Users\" or Target contains @"\Temp\" or Target contains @"\AppData\"),
        array_concat(_flags, dynamic(["ElevatedUserPath"])), _flags)
    // -- NeverLoggedIn: enabled local account with zero logins
    | extend _flags = iff(PersistenceType == "LocalAccount"
        and Enabled == "enabled"
        and toint(tostring(Details.LoginCount)) == 0,
        array_concat(_flags, dynamic(["NeverLoggedIn"])), _flags)
    // -- DisabledWithHash: disabled account with a non-default password hash
    | extend _flags = iff(PersistenceType == "LocalAccount"
        and Enabled == "disabled"
        and Hash != ""
        and Hash != "31d6cfe0d16ae931b73c59d7e0c089c0",
        array_concat(_flags, dynamic(["DisabledWithHash"])), _flags)
    // -- Assemble final column and clean up
    | extend Suspicious = iff(array_length(_flags) > 0, strcat_array(_flags, ", "), "")
    | project-away _flags, _isRealEntry
    | project
        PersistenceType,
        Name,
        Target,
        EntryLocation,
        User,
        Enabled,
        Signer,
        Hash,
        Suspicious,
        Details,
        LastModified,
        SourceArtifact,
        Hostname,
        Organization,
        ClientId,
        FlowId,
        IngestionTime
    | sort by Suspicious desc, PersistenceType asc, Name asc
}

// Companion function: returns all PersistenceType values and their source tables
// Usage:
//   WindowsPersistenceOverviewSchema()
//   WindowsPersistenceOverviewSchema() | where PersistenceType == "ScheduledTask"
.create-or-alter function with (folder="Analysis", docstring="Returns all PersistenceType/SourceTable mappings available in WindowsPersistenceOverview().", skipvalidation="true")
WindowsPersistenceOverviewSchema() {
    datatable(PersistenceType:string, SourceTable:string, Description:string) [
        "(Autoruns Category)",  "WindowsSysinternalsAutoruns",               "Sysinternals Autoruns — Category values: Boot Execute, Codecs, Drivers, Explorer, Image Hijacks, KnownDLLs, Logon, LSA Providers, Network Providers, Office, Print Monitors, Scheduled Tasks, Services, Sidebar Gadgets, Winlogon, Winsock Providers",
        "ScheduledTask",        "WindowsRegistryScheduledTasks",             "Scheduled tasks parsed from registry (Mtime timestamp)",
        "StartupItem",          "WindowsPacksPersistenceStartupItems + WindowsSysStartupItems", "Startup folder/registry items (deduplicated)",
        "WMISubscription",      "WindowsPacksPersistenceWMIEventFilters",    "WMI event filter/consumer bindings",
        "WMIProvider",          "WindowsSystemWMIProviders",                 "Registered WMI providers and their DLL paths",
        "LocalAccount",         "WindowsForensicsSAMParsed + WindowsForensicsSAMCreateTimes", "Local user accounts from SAM (CreatedTime, LastLoginDate)",
        "LocalAdmin",           "WindowsSystemLocalAdmins",                  "Local Administrators group members"
    ]
}

// ============================================
// Source: analysis/Windows.Supertimeline.Timeline.kql
// ============================================

//ARTIFACT: Windows.Supertimeline.Timeline
// Windows Supertimeline — unions all Windows artifact tables into a single
// schema for cross-artifact chronological analysis during incident response.
//
// Phase 1: Core forensic timeline (30 union legs) + 10 DetectRaptor detection legs
//
// Categories & EventTypes:
//   Execution       — PrefetchTimeline, PrefetchHit, ProcessCreation, AmcacheInventory,
//                     AmcacheDetection, AppCompatExecution, UserAssist, SRUMExecution,
//                     ForensicTimeline, CertUtilDownload, SRUMAppResource
//   FileSystem      — MFTTimeline, USNChange, RecycleBinDelete, Download
//   EventLog        — HayabusaAlert, EvtxEvent, HayabusaResult
//   Detection       — SuspiciousParent, Malfind, DetectRaptorApplications, DetectRaptorEvtx,
//                     DetectRaptorBinaryRename, DetectRaptorHijackLibs, DetectRaptorAmcache,
//                     DetectRaptorLolRMM, DetectRaptorMFT, DetectRaptorPSReadline,
//                     DetectRaptorWebhistory, DetectRaptorYaraProcess
//   Persistence     — ScheduledTask, Autorun
//   Authentication  — LateralMovement, SAMAccountCreated, SAMAccountActivity
//   Network         — SRUMNetworkUsage, SRUMNetworkConnection
//   UserActivity    — LnkFile, Shellbag, Clipboard
//
// Queryable reference: WindowsSupertimelineSchema() returns all category/type/source mappings
//
// Usage:
//   WindowsSupertimeline(ago(30d), now())
//   WindowsSupertimeline(ago(7d), now(), targetHostname="DESKTOP-ABC")
//   WindowsSupertimeline(ago(7d), now(), filterEventCategory="Execution")
//   WindowsSupertimeline(ago(7d), now(), filterEventCategory="Execution,Persistence")
//   WindowsSupertimeline(ago(7d), now(), filterEventCategory="Execution", filterEventType="Prefetch,Amcache")
//   WindowsSupertimeline(ago(7d), now(), filterUser="admin")
//   WindowsSupertimeline(ago(7d), now(), filterDescription="mimikatz")
//
// Description convention: [Source] Action | Target | Key Detail | Flags

.create-or-alter function with (folder="Analysis", docstring="Windows supertimeline — unions all Windows artifact tables into a single schema for cross-artifact chronological analysis.", skipvalidation="true")
WindowsSupertimeline(
    startTime:datetime,
    endTime:datetime,
    targetHostname:string = "",
    targetOrg:string = "",
    filterEventCategory:string = "",
    filterEventType:string = "",
    filterPath:string = "",
    filterUser:string = "",
    filterDescription:string = ""
) {
    let _start = startTime;
    let _end = endTime;
    let _host = targetHostname;
    let _org = targetOrg;
    let _fCategory = filterEventCategory;
    let _fType = filterEventType;
    let _fCategoryList = iff(isempty(_fCategory), dynamic([]), split(_fCategory, ","));
    let _fTypeList     = iff(isempty(_fType), dynamic([]), split(_fType, ","));
    let _fPath = filterPath;
    let _fUser = filterUser;
    let _fDescription = filterDescription;
    // ========================================================================
    // Execution
    // ========================================================================
    // [Execution] WindowsTimelinePrefetchImproved — Prefetch timeline (already timeline-formatted)
    let _timelinePrefetch =
        WindowsTimelinePrefetchImproved
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "PrefetchTimeline" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "PrefetchTimeline",
            Description    = strcat("[Prefetch] ", Message, " | ", Source, " | Count: ", tostring(PrefetchCount)),
            User           = "",
            Path           = coalesce(Source, ""),
            Hash           = coalesce(PrefetchHash, ""),
            Details        = bag_pack(
                                "FileName", FileName,
                                "PrefetchFile", PrefetchFile,
                                "PrefetchVersion", PrefetchVersion,
                                "PrefetchSize", PrefetchSize,
                                "PrefetchCtime", PrefetchCtime,
                                "PrefetchMtime", PrefetchMtime,
                                "Parser", Parser
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsForensicsPrefetch — Prefetch forensic detail
    let _forensicsPrefetch =
        WindowsForensicsPrefetch
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "PrefetchHit" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "PrefetchHit",
            Description    = strcat("[Prefetch] Execution: ", Executable, " | ", coalesce(OSPath, ""), " | Runs: ", tostring(RunCount)),
            User           = "",
            Path           = coalesce(ExecutablePath, OSPath, ""),
            Hash           = coalesce(Hash, ""),
            Details        = bag_pack(
                                "RunCount", RunCount,
                                "LastRunTimes", LastRunTimes,
                                "PrefetchFileName", PrefetchFileName,
                                "CreationTime", CreationTime,
                                "ModificationTime", ModificationTime,
                                "Binary", Binary,
                                "Version", Version,
                                "FilesAccessed", FilesAccessed
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsSystemPslist — Running processes (uses CreateTime, not collection Timestamp)
    let _pslist =
        WindowsSystemPslist
        | where isnotempty(CreateTime)
        | where CreateTime between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "ProcessCreation" in (_fTypeList)
        | project
            EventTime      = CreateTime,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "ProcessCreation",
            Description    = strcat("[Process] Started | ", Name, " | PID: ", tostring(Pid), " | PPID: ", tostring(Ppid), " | User: ", coalesce(Username, "")),
            User           = coalesce(Username, ""),
            Path           = coalesce(Exe, ""),
            Hash           = coalesce(SHA256, SHA1, MD5, ""),
            Details        = bag_pack(
                                "Pid", Pid,
                                "Ppid", Ppid,
                                "CommandLine", CommandLine,
                                "CreateTime", CreateTime,
                                "Trusted", Trusted,
                                "Subject", Subject,
                                "IssuerName", IssuerName,
                                "TokenIsElevated", TokenIsElevated
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsSystemAmcacheInventoryApplicationFile — Amcache inventory
    let _amcacheInventory =
        WindowsSystemAmcacheInventoryApplicationFile
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "AmcacheInventory" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "AmcacheInventory",
            Description    = strcat("[Amcache] Inventory: ", Name, " | ", coalesce(Binary, ""), " | Publisher: ", coalesce(Publisher, "")),
            User           = "",
            Path           = coalesce(Binary, ""),
            Hash           = coalesce(FileId, ""),
            Details        = bag_pack(
                                "Name", Name,
                                "Size", Size,
                                "Version", Version,
                                "BinFileVersion", BinFileVersion,
                                "ProductName", ProductName,
                                "Publisher", Publisher,
                                "LastModified", LastModified,
                                "Key", Key,
                                "Hive", Hive
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsDetectionAmcache — Amcache detection
    let _amcacheDetection =
        WindowsDetectionAmcache
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "AmcacheDetection" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "AmcacheDetection",
            Description    = strcat("[Amcache] Detection: ", EntryName, " | ", coalesce(EntryPath, ""), " | Type: ", coalesce(EntryType, "")),
            User           = "",
            Path           = coalesce(EntryPath, ""),
            Hash           = coalesce(SHA1, ""),
            Details        = bag_pack(
                                "EntryKey", EntryKey,
                                "KeyMTime", KeyMTime,
                                "EntryType", EntryType,
                                "OriginalFileName", OriginalFileName,
                                "Publisher", Publisher,
                                "BinaryType", BinaryType,
                                "HivePath", HivePath
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsSystemAppCompatPCA — AppCompat program execution
    let _appCompatPCA =
        WindowsSystemAppCompatPCA
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "AppCompatExecution" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "AppCompatExecution",
            Description    = strcat("[AppCompat] Execution: ", coalesce(FullPath, ExePath, "")),
            User           = "",
            Path           = coalesce(FullPath, ExePath, ""),
            Hash           = "",
            Details        = bag_pack(
                                "ExePath", ExePath,
                                "FullPath", FullPath,
                                "LastExecuted", LastExecuted
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsRegistryUserAssist — User application execution
    let _userAssist =
        WindowsRegistryUserAssist
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "UserAssist" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "UserAssist",
            Description    = strcat("[UserAssist] Execution: ", Name, " | Runs: ", tostring(NumberOfExecutions), " | User: ", coalesce(User, "")),
            User           = coalesce(User, ""),
            Path           = coalesce(Name, ""),
            Hash           = "",
            Details        = bag_pack(
                                "KeyPath", KeyPath,
                                "LastExecution", LastExecution,
                                "LastExecutionTS", LastExecutionTS,
                                "NumberOfExecutions", NumberOfExecutions
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsForensicsSRUMExecutionStats — SRUM execution statistics
    let _srumExecution =
        WindowsForensicsSRUMExecutionStats
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "SRUMExecution" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "SRUMExecution",
            Description    = strcat("[SRUM] Execution: ", App, " | User: ", coalesce(User, ""), " | Duration: ", tostring(DurationMS), "ms"),
            User           = coalesce(User, ""),
            Path           = coalesce(App, ""),
            Hash           = "",
            Details        = bag_pack(
                                "App", App,
                                "UserSid", UserSid,
                                "EndTime", EndTime,
                                "DurationMS", DurationMS,
                                "NetworkBytesRaw", NetworkBytesRaw,
                                "ID", ID
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsForensicsTimeline — General forensic timeline
    let _forensicsTimeline =
        WindowsForensicsTimeline
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "ForensicTimeline" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "ForensicTimeline",
            Description    = strcat("[Timeline] Execution: ", Application, " | User: ", coalesce(User, "")),
            User           = coalesce(User, ""),
            Path           = coalesce(Application, ""),
            Hash           = "",
            Details        = bag_pack(
                                "Application", Application,
                                "LastExecutionTS", LastExecutionTS,
                                "LastModifiedTime", tostring(LastModifiedTime)
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsForensicsCertUtil — CertUtil download cache (LOLBin)
    let _certUtil =
        WindowsForensicsCertUtil
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
