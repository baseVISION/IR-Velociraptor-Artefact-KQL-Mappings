    System: dynamic,
    EventData: dynamic,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
) 

.create-or-alter function RouteLinuxForensicsJournal() {
    RawVelociraptorEvents
    | where Artifact == "Linux.Forensics.Journal"
    | extend 
        System = RawData.System,
        EventData = RawData.EventData
    | extend Timestamp = unixtime_microseconds_todatetime(tolong(RawData.System.__REALTIME_TIMESTAMP))
    | project
        Timestamp,
        Hostname,
        System,
        EventData,
        Artifact,
        Organization,
        ClientId,
        FlowId,
        IngestionTime
}

