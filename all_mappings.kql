//ARTIFACT: Generic.Applications.Chrome.SessionStorage
.create table GenericApplicationsChromeSessionStorage (
    Timestamp: datetime,
    Hostname: string,
    OSPath: string,
    URL: string,
    GUID: string,
    Mapping: dynamic,
    Artifact: string,
    Organization: string,
    ClientId: string,
    FlowId: string,
    IngestionTime: datetime
)

.create-or-alter function RouteGenericApplicationsChromeSessionStorage() {
    RawVelociraptorEvents
    | where Artifact == "Generic.Applications.Chrome.SessionStorage"
    | extend 
        OSPath = tostring(RawData.OSPath),
        URL = tostring(RawData.URL),
        GUID = tostring(RawData.GUID),
        Mapping = RawData.Mapping
    | project 
        Timestamp, 
        Hostname, 
        OSPath,
        URL,
        GUID,
        Mapping,
        Artifact,
        Organization,
        ClientId, 
        FlowId, 
        IngestionTime
}

.alter table GenericApplicationsChromeSessionStorage policy update @'[{"IsEnabled":true,"Source":"RawVelociraptorEvents","Query":"RouteGenericApplicationsChromeSessionStorage()","IsTransactional":false}]'

