        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Detection" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "DetectRaptorMFT" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Detection",
            EventType      = "DetectRaptorMFT",
            Description    = strcat("[DetectRaptor] MFT | ", DetectionName, " [", coalesce(DetectionCriticality, ""), "] | ", coalesce(OSPath, ""), " | Size: ", tostring(FileSize)),
            User           = "",
            Path           = coalesce(OSPath, ""),
            Hash           = "",
            Details        = bag_pack(
                                "DetectionName", DetectionName,
                                "DetectionCriticality", DetectionCriticality,
                                "DetectionStringHit", DetectionStringHit,
                                "EntryNumber", EntryNumber,
                                "InUse", InUse,
                                "SICreated", SICreated,
                                "SILastModified", SILastModified,
                                "FNCreated", FNCreated,
                                "FNLastModified", FNLastModified,
                                "SITimestamps", SITimestamps,
                                "FNTimestamps", FNTimestamps
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Detection] DetectRaptorWindowsDetectionPowershellPSReadline — Suspicious PowerShell command detections
    let _drPSReadline =
        DetectRaptorWindowsDetectionPowershellPSReadline
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Detection" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "DetectRaptorPSReadline" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Detection",
            EventType      = "DetectRaptorPSReadline",
            Description    = strcat("[DetectRaptor] PSReadline | ", RuleName, " | User: ", coalesce(Username, ""), " | Line: ", coalesce(Line, "")),
            User           = coalesce(Username, ""),
            Path           = "",
            Hash           = "",
            Details        = bag_pack(
                                "RuleID", RuleID,
                                "RuleName", RuleName,
                                "RuleRegex", RuleRegex,
                                "LineNum", LineNum,
                                "Line", Line,
                                "FileMtime", FileMtime,
                                "FileSize", FileSize
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Detection] DetectRaptorWindowsDetectionWebhistory — Suspicious web browsing detections
    let _drWebhistory =
        DetectRaptorWindowsDetectionWebhistory
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Detection" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "DetectRaptorWebhistory" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Detection",
            EventType      = "DetectRaptorWebhistory",
            Description    = strcat("[DetectRaptor] Webhistory | ", DetectionCategory, " | ", coalesce(Domain, ""), " | ", coalesce(URL, ""), " | User: ", coalesce(User, "")),
            User           = coalesce(User, ""),
            Path           = coalesce(OSPath, ""),
            Hash           = "",
            Details        = bag_pack(
                                "DetectionCategory", DetectionCategory,
                                "DetectionDomainRegex", DetectionDomainRegex,
                                "DetectionComment", DetectionComment,
                                "Domain", Domain,
                                "Category", Category,
                                "BrowserArtifact", BrowserArtifact,
                                "URL", URL,
                                "Title", Title,
                                "VisitDate", VisitDate,
                                "LastVisitDate", LastVisitDate
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Detection] DetectRaptorWindowsDetectionYaraProcessWin — YARA process memory scan detections
    let _drYaraProcess =
        DetectRaptorWindowsDetectionYaraProcessWin
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Detection" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "DetectRaptorYaraProcess" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Detection",
            EventType      = "DetectRaptorYaraProcess",
            Description    = strcat("[DetectRaptor] YaraProcess | ", Rule, " | ", coalesce(ProcessName, ""), " (PID: ", tostring(Pid), ") | ", coalesce(ExePath, "")),
            User           = "",
            Path           = coalesce(ExePath, ""),
            Hash           = "",
            Details        = bag_pack(
                                "Rule", Rule,
                                "ProcessName", ProcessName,
                                "Pid", Pid,
                                "CommandLine", CommandLine,
                                "Namespace", Namespace,
                                "YaraString", YaraString,
                                "MetaDescription", MetaDescription,
                                "MetaAuthor", MetaAuthor,
                                "MetaReference", MetaReference,
                                "MetaScore", MetaScore,
                                "Meta", Meta
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // Union all legs + post-filter
    // ========================================================================
    union isfuzzy=true
        // Execution
        _timelinePrefetch,
        _forensicsPrefetch,
        _pslist,
        _amcacheInventory,
        _amcacheDetection,
        _appCompatPCA,
        _userAssist,
        _srumExecution,
        _forensicsTimeline,
        _certUtil,
        _srumAppResource,
        // FileSystem
        _timelineMft,
        _usn,
        _recycleBin,
        _evidenceOfDownload,
        // EventLogs / Detections
        _hayabusaRules,
        _evtx,
        _hayabusaResults,
        // Detection
        _attackParentProcess,
        _malfind,
        // DetectRaptor Detections
        _drApplications,
        _drEvtx,
        _drBinaryRename,
        _drHijackLibs,
        _drAmcache,
        _drLolRMM,
        _drMFT,
        _drPSReadline,
        _drWebhistory,
        _drYaraProcess,
        // Persistence
        _scheduledTasks,
        _autoruns,
        // Authentication / Lateral Movement
        _lateralMovement,
        _samCreate,
        _samParsed,
        // Network
        _srumNetworkUsage,
        _srumNetworkConnections,
        // User Activity
        _lnk,
        _shellbags,
        _clipboard
    | extend Path = replace_string(Path, " -> ", "\\")
    | where array_length(_fCategoryList) == 0 or EventCategory has_any (_fCategoryList)
    | where array_length(_fTypeList)     == 0 or EventType     has_any (_fTypeList)
    | where isempty(_fPath) or Path          contains _fPath
    | where isempty(_fUser) or User          contains _fUser
    | where isempty(_fDescription) or Description   has _fDescription
    | order by EventTime asc
}

// Companion function: returns all valid EventCategory / EventType combinations
// Usage:
//   WindowsSupertimelineSchema()
//   WindowsSupertimelineSchema() | where EventCategory == "Execution"
//   WindowsSupertimelineSchema() | summarize Types=make_list(EventType) by EventCategory
.create-or-alter function with (folder="Analysis", docstring="Returns all EventCategory/EventType/SourceTable mappings available in WindowsSupertimeline().", skipvalidation="true")
WindowsSupertimelineSchema() {
    datatable(EventCategory:string, EventType:string, SourceTable:string, Description:string) [
        "Execution",      "PrefetchTimeline",    "WindowsTimelinePrefetchImproved",                "Prefetch timeline (pre-formatted MACB events)",
        "Execution",      "PrefetchHit",         "WindowsForensicsPrefetch",                       "Prefetch forensic detail per executable",
        "Execution",      "ProcessCreation",     "WindowsSystemPslist",                            "Running processes (kernel CreateTime)",
        "Execution",      "AmcacheInventory",    "WindowsSystemAmcacheInventoryApplicationFile",   "Amcache application inventory",
        "Execution",      "AmcacheDetection",    "WindowsDetectionAmcache",                        "Amcache-based execution detection",
        "Execution",      "AppCompatExecution",  "WindowsSystemAppCompatPCA",                      "AppCompat PCA program execution",
        "Execution",      "UserAssist",          "WindowsRegistryUserAssist",                      "User-launched application (Explorer)",
        "Execution",      "SRUMExecution",       "WindowsForensicsSRUMExecutionStats",             "SRUM execution statistics",
        "Execution",      "ForensicTimeline",    "WindowsForensicsTimeline",                       "General forensic timeline events",
        "Execution",      "CertUtilDownload",    "WindowsForensicsCertUtil",                       "CertUtil download cache (LOLBin)",
        "Execution",      "SRUMAppResource",     "WindowsForensicsSRUMApplicationResourceUsage",   "SRUM application resource usage",
        "FileSystem",     "MFTTimeline",         "WindowsTimelineMFT",                             "MFT timeline (MACB decomposed, $MFT/$LogFile/$UsnJrnl)",
        "FileSystem",     "USNChange",           "WindowsForensicsUsn",                            "USN journal change records",
        "FileSystem",     "RecycleBinDelete",    "WindowsForensicsRecycleBin",                     "Recycle Bin deleted files",
        "FileSystem",     "Download",            "WindowsAnalysisEvidenceOfDownload",              "Downloaded files (Zone.Identifier ADS)",
        "EventLog",       "HayabusaAlert",       "WindowsHayabusaRules",                           "Sigma/Hayabusa detection rule matches",
        "EventLog",       "EvtxEvent",           "WindowsEventLogsEvtx",                           "Raw Windows event log entries",
        "EventLog",       "HayabusaResult",      "WindowsEventLogsHayabusaResults",                "Hayabusa parsed results",
        "Detection",      "SuspiciousParent",    "WindowsAttackParentProcess",                     "Suspicious parent-child process relationships",
        "Detection",      "Malfind",             "WindowsDetectionMalfind",                        "Injected code / suspicious memory sections",
        "Detection",      "DetectRaptorApplications", "DetectRaptorWindowsDetectionApplications",  "DetectRaptor suspicious installed applications",
        "Detection",      "DetectRaptorEvtx",    "DetectRaptorWindowsDetectionEvtx",               "DetectRaptor event log detections",
        "Detection",      "DetectRaptorBinaryRename", "DetectRaptorWindowsDetectionBinaryRename",  "DetectRaptor renamed binary detections",
        "Detection",      "DetectRaptorHijackLibs", "DetectRaptorWindowsDetectionHijackLibsMFT",   "DetectRaptor DLL hijack detections",
        "Detection",      "DetectRaptorAmcache", "DetectRaptorWindowsDetectionAmcache",            "DetectRaptor Amcache suspicious binary detections",
        "Detection",      "DetectRaptorLolRMM",  "DetectRaptorWindowsDetectionLolRMM",             "DetectRaptor remote management tool detections",
        "Detection",      "DetectRaptorMFT",     "DetectRaptorWindowsDetectionMFT",                "DetectRaptor MFT suspicious file detections",
        "Detection",      "DetectRaptorPSReadline", "DetectRaptorWindowsDetectionPowershellPSReadline", "DetectRaptor suspicious PowerShell commands",
        "Detection",      "DetectRaptorWebhistory", "DetectRaptorWindowsDetectionWebhistory",      "DetectRaptor suspicious web browsing detections",
        "Detection",      "DetectRaptorYaraProcess", "DetectRaptorWindowsDetectionYaraProcessWin", "DetectRaptor YARA process memory scan detections",
        "Persistence",    "ScheduledTask",       "WindowsRegistryScheduledTasks",                  "Scheduled tasks (registry Mtime)",
        "Persistence",    "Autorun",             "WindowsSysinternalsAutoruns",                    "Autorun persistence entries",
        "Authentication", "LateralMovement",     "WindowsPacksLateralMovementAlternateLogon",      "Lateral movement alternate logon events",
        "Authentication", "SAMAccountCreated",   "WindowsForensicsSAMCreateTimes",                 "SAM account creation times",
        "Authentication", "SAMAccountActivity",  "WindowsForensicsSAMParsed",                      "SAM account last login activity",
        "Network",        "SRUMNetworkUsage",    "WindowsForensicsSRUMNetworkUsage",               "SRUM network bytes per application",
        "Network",        "SRUMNetworkConnection","WindowsForensicsSRUMNetworkConnections",        "SRUM network connection records",
        "UserActivity",   "LnkFile",             "WindowsForensicsLnk",                            "LNK shortcut file timestamps",
        "UserActivity",   "Shellbag",            "WindowsForensicsShellbags",                      "Explorer folder navigation history",
        "UserActivity",   "Clipboard",           "WindowsForensicsClipboard",                      "Clipboard history entries"
    ]
}
