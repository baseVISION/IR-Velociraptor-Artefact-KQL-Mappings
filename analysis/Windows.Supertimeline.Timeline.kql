            User           = coalesce(Username, ""),
            Path           = coalesce(Exe, ""),
            Hash           = "",
            Details        = bag_pack(
                                "ActualProcessName", ActualProcessName,
                                "ActualParentName", ActualParentName,
                                "ExpectedParentName", ExpectedParentName,
