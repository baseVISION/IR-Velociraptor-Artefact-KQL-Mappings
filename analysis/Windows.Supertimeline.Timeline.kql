//ARTIFACT: Windows.Supertimeline.Timeline
// Windows Supertimeline — unions all Windows artifact tables into a single
// schema for cross-artifact chronological analysis during incident response.
//
// Phase 1: Core forensic timeline (30 union legs) + 10 DetectRaptor detection legs
//
// Categories & EventTypes:
//   Execution       — PrefetchTimeline, PrefetchHit, ProcessCreation, AmcacheInventory,
//                     AmcacheDetection, AppCompatExecution, UserAssist, SRUMExecution,
//                     ForensicTimeline, CertUtilDownload, SRUMAppResource
//   FileSystem      — MFTTimeline, USNChange, RecycleBinDelete, Download
//   EventLog        — HayabusaAlert, EvtxEvent, HayabusaResult
//   Detection       — SuspiciousParent, Malfind, DetectRaptorApplications, DetectRaptorEvtx,
//                     DetectRaptorBinaryRename, DetectRaptorHijackLibs, DetectRaptorAmcache,
//                     DetectRaptorLolRMM, DetectRaptorMFT, DetectRaptorPSReadline,
//                     DetectRaptorWebhistory, DetectRaptorYaraProcess
//   Persistence     — ScheduledTask, Autorun
//   Authentication  — LateralMovement, SAMAccountCreated, SAMAccountActivity
//   Network         — SRUMNetworkUsage, SRUMNetworkConnection
//   UserActivity    — LnkFile, Shellbag, Clipboard
//
// Queryable reference: WindowsSupertimelineSchema() returns all category/type/source mappings
//
// Usage:
//   WindowsSupertimeline(ago(30d), now())
//   WindowsSupertimeline(ago(7d), now(), targetHostname="DESKTOP-ABC")
//   WindowsSupertimeline(ago(7d), now(), filterEventCategory="Execution")
//   WindowsSupertimeline(ago(7d), now(), filterEventCategory="Execution,Persistence")
//   WindowsSupertimeline(ago(7d), now(), filterEventCategory="Execution", filterEventType="Prefetch,Amcache")
//   WindowsSupertimeline(ago(7d), now(), filterUser="admin")
//   WindowsSupertimeline(ago(7d), now(), filterDescription="mimikatz")
//
// Description convention: [Source] Action | Target | Key Detail | Flags

.create-or-alter function with (folder="Analysis", docstring="Windows supertimeline — unions all Windows artifact tables into a single schema for cross-artifact chronological analysis.", skipvalidation="true")
WindowsSupertimeline(
    startTime:datetime,
    endTime:datetime,
    targetHostname:string = "",
    targetOrg:string = "",
    filterEventCategory:string = "",
    filterEventType:string = "",
    filterPath:string = "",
    filterUser:string = "",
    filterDescription:string = ""
) {
    let _start = startTime;
    let _end = endTime;
    let _host = targetHostname;
    let _org = targetOrg;
    let _fCategory = filterEventCategory;
    let _fType = filterEventType;
    let _fCategoryList = iff(isempty(_fCategory), dynamic([]), split(_fCategory, ","));
    let _fTypeList     = iff(isempty(_fType), dynamic([]), split(_fType, ","));
    let _fPath = filterPath;
    let _fUser = filterUser;
    let _fDescription = filterDescription;
    // ========================================================================
    // Execution
    // ========================================================================
    // [Execution] WindowsTimelinePrefetchImproved — Prefetch timeline (already timeline-formatted)
    let _timelinePrefetch =
        WindowsTimelinePrefetchImproved
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "PrefetchTimeline" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "PrefetchTimeline",
            Description    = strcat("[Prefetch] ", Message, " | ", Source, " | Count: ", tostring(PrefetchCount)),
            User           = "",
            Path           = coalesce(Source, ""),
            Hash           = coalesce(PrefetchHash, ""),
            Details        = bag_pack(
                                "FileName", FileName,
                                "PrefetchFile", PrefetchFile,
                                "PrefetchVersion", PrefetchVersion,
                                "PrefetchSize", PrefetchSize,
                                "PrefetchCtime", PrefetchCtime,
                                "PrefetchMtime", PrefetchMtime,
                                "Parser", Parser
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsForensicsPrefetch — Prefetch forensic detail
    let _forensicsPrefetch =
        WindowsForensicsPrefetch
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "PrefetchHit" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "PrefetchHit",
            Description    = strcat("[Prefetch] Execution: ", Executable, " | ", coalesce(OSPath, ""), " | Runs: ", tostring(RunCount)),
            User           = "",
            Path           = coalesce(ExecutablePath, OSPath, ""),
            Hash           = coalesce(Hash, ""),
            Details        = bag_pack(
                                "RunCount", RunCount,
                                "LastRunTimes", LastRunTimes,
                                "PrefetchFileName", PrefetchFileName,
                                "CreationTime", CreationTime,
                                "ModificationTime", ModificationTime,
                                "Binary", Binary,
                                "Version", Version,
                                "FilesAccessed", FilesAccessed
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsSystemPslist — Running processes (uses CreateTime, not collection Timestamp)
    let _pslist =
        WindowsSystemPslist
        | where isnotempty(CreateTime)
        | where CreateTime between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "ProcessCreation" in (_fTypeList)
        | project
            EventTime      = CreateTime,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "ProcessCreation",
            Description    = strcat("[Process] Started | ", Name, " | PID: ", tostring(Pid), " | PPID: ", tostring(Ppid), " | User: ", coalesce(Username, "")),
            User           = coalesce(Username, ""),
            Path           = coalesce(Exe, ""),
            Hash           = coalesce(SHA256, SHA1, MD5, ""),
            Details        = bag_pack(
                                "Pid", Pid,
                                "Ppid", Ppid,
                                "CommandLine", CommandLine,
                                "CreateTime", CreateTime,
                                "Trusted", Trusted,
                                "Subject", Subject,
                                "IssuerName", IssuerName,
                                "TokenIsElevated", TokenIsElevated
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsSystemAmcacheInventoryApplicationFile — Amcache inventory
    let _amcacheInventory =
        WindowsSystemAmcacheInventoryApplicationFile
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "AmcacheInventory" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "AmcacheInventory",
            Description    = strcat("[Amcache] Inventory: ", Name, " | ", coalesce(Binary, ""), " | Publisher: ", coalesce(Publisher, "")),
            User           = "",
            Path           = coalesce(Binary, ""),
            Hash           = coalesce(FileId, ""),
            Details        = bag_pack(
                                "Name", Name,
                                "Size", Size,
                                "Version", Version,
                                "BinFileVersion", BinFileVersion,
                                "ProductName", ProductName,
                                "Publisher", Publisher,
                                "LastModified", LastModified,
                                "Key", Key,
                                "Hive", Hive
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsDetectionAmcache — Amcache detection
    let _amcacheDetection =
        WindowsDetectionAmcache
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "AmcacheDetection" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "AmcacheDetection",
            Description    = strcat("[Amcache] Detection: ", EntryName, " | ", coalesce(EntryPath, ""), " | Type: ", coalesce(EntryType, "")),
            User           = "",
            Path           = coalesce(EntryPath, ""),
            Hash           = coalesce(SHA1, ""),
            Details        = bag_pack(
                                "EntryKey", EntryKey,
                                "KeyMTime", KeyMTime,
                                "EntryType", EntryType,
                                "OriginalFileName", OriginalFileName,
                                "Publisher", Publisher,
                                "BinaryType", BinaryType,
                                "HivePath", HivePath
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsSystemAppCompatPCA — AppCompat program execution
    let _appCompatPCA =
        WindowsSystemAppCompatPCA
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "AppCompatExecution" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "AppCompatExecution",
            Description    = strcat("[AppCompat] Execution: ", coalesce(FullPath, ExePath, "")),
            User           = "",
            Path           = coalesce(FullPath, ExePath, ""),
            Hash           = "",
            Details        = bag_pack(
                                "ExePath", ExePath,
                                "FullPath", FullPath,
                                "LastExecuted", LastExecuted
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsRegistryUserAssist — User application execution
    let _userAssist =
        WindowsRegistryUserAssist
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "UserAssist" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "UserAssist",
            Description    = strcat("[UserAssist] Execution: ", Name, " | Runs: ", tostring(NumberOfExecutions), " | User: ", coalesce(User, "")),
            User           = coalesce(User, ""),
            Path           = coalesce(Name, ""),
            Hash           = "",
            Details        = bag_pack(
                                "KeyPath", KeyPath,
                                "LastExecution", LastExecution,
                                "LastExecutionTS", LastExecutionTS,
                                "NumberOfExecutions", NumberOfExecutions
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsForensicsSRUMExecutionStats — SRUM execution statistics
    let _srumExecution =
        WindowsForensicsSRUMExecutionStats
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "SRUMExecution" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "SRUMExecution",
            Description    = strcat("[SRUM] Execution: ", App, " | User: ", coalesce(User, ""), " | Duration: ", tostring(DurationMS), "ms"),
            User           = coalesce(User, ""),
            Path           = coalesce(App, ""),
            Hash           = "",
            Details        = bag_pack(
                                "App", App,
                                "UserSid", UserSid,
                                "EndTime", EndTime,
                                "DurationMS", DurationMS,
                                "NetworkBytesRaw", NetworkBytesRaw,
                                "ID", ID
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsForensicsTimeline — General forensic timeline
    let _forensicsTimeline =
        WindowsForensicsTimeline
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "ForensicTimeline" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "ForensicTimeline",
            Description    = strcat("[Timeline] Execution: ", Application, " | User: ", coalesce(User, "")),
            User           = coalesce(User, ""),
            Path           = coalesce(Application, ""),
            Hash           = "",
            Details        = bag_pack(
                                "Application", Application,
                                "LastExecutionTS", LastExecutionTS,
                                "LastModifiedTime", tostring(LastModifiedTime)
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsForensicsCertUtil — CertUtil download cache (LOLBin)
    let _certUtil =
        WindowsForensicsCertUtil
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "CertUtilDownload" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "CertUtilDownload",
            Description    = strcat("[CertUtil] Download | URL: ", coalesce(URL, ""), " | TLD: ", coalesce(UrlTLD, ""), " | Size: ", tostring(FileSize)),
            User           = "",
            Path           = coalesce(ContentPath, ""),
            Hash           = coalesce(Hash, ""),
            Details        = bag_pack(
                                "URL", URL,
                                "UrlTLD", UrlTLD,
                                "FileSize", FileSize,
                                "VersionInformation", VersionInformation,
                                "Authenticode", Authenticode,
                                "MetadataFile", MetadataFile,
                                "ContentPath", ContentPath
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [Execution] WindowsForensicsSRUMApplicationResourceUsage — SRUM app resource usage
    let _srumAppResource =
        WindowsForensicsSRUMApplicationResourceUsage
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Execution" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "SRUMAppResource" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Execution",
            EventType      = "SRUMAppResource",
            Description    = strcat("[SRUM] AppResource: ", App, " | User: ", coalesce(User, "")),
            User           = coalesce(User, ""),
            Path           = coalesce(App, ""),
            Hash           = "",
            Details        = bag_pack(
                                "App", App,
                                "UserSid", UserSid,
                                "SRUMId", SRUMId,
                                "ForegroundCycleTime", ForegroundCycleTime,
                                "BackgroundCycleTime", BackgroundCycleTime,
                                "FaceTime", FaceTime,
                                "ForegroundBytesRead", ForegroundBytesRead,
                                "ForegroundBytesWritten", ForegroundBytesWritten,
                                "BackgroundBytesRead", BackgroundBytesRead,
                                "BackgroundBytesWritten", BackgroundBytesWritten
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // FileSystem
    // ========================================================================
    // [FileSystem] WindowsTimelineMFT — MFT timeline (already timeline-formatted)
    let _timelineMft =
        WindowsTimelineMFT
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "FileSystem" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "MFTTimeline" in (_fTypeList)
        | extend _flags = strcat_array(
            array_concat(
                iff(FNCreatedShift, dynamic(["FNCreatedShift"]), dynamic([])),
                iff(USecZero,       dynamic(["USecZero"]),       dynamic([])),
                iff(PossibleCopy,   dynamic(["PossibleCopy"]),   dynamic([])),
                iff(VolumeCopy,     dynamic(["VolumeCopy"]),     dynamic([]))
            ), ", ")
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "FileSystem",
            EventType      = "MFTTimeline",
            Description    = strcat("[", Source, "] ", Message, " | ", Path,
                              " | Size: ", tostring(FileSize),
                              iff(_flags == "", "", strcat(" | Flags: ", _flags))),
            User           = "",
            Path,
            Hash           = "",
            Details        = bag_pack(
                                "EntryNumber", EntryNumber,
                                "ParentEntryNumber", ParentEntryNumber,
                                "IsDir", IsDir,
                                "InUse", InUse,
                                "SI_Created", SI_Created,
                                "SI_LastModified", SI_LastModified,
                                "SI_LastAccess", SI_LastAccess,
                                "SI_LastRecordChange", SI_LastRecordChange,
                                "FN_Created", FN_Created,
                                "FN_LastModified", FN_LastModified,
                                "FN_LastAccess", FN_LastAccess,
                                "FN_LastRecordChange", FN_LastRecordChange,
                                "Parser", Parser
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [FileSystem] WindowsForensicsUsn — USN journal changes
    let _usn =
        WindowsForensicsUsn
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "FileSystem" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "USNChange" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "FileSystem",
            EventType      = "USNChange",
            Description    = strcat("[USN] Change | ", Filename, " | ", coalesce(OSPath, ""), " | Reason: ", tostring(Reason)),
            User           = "",
            Path           = coalesce(OSPath, ""),
            Hash           = "",
            Details        = bag_pack(
                                "Filename", Filename,
                                "MFTId", MFTId,
                                "Sequence", Sequence,
                                "ParentMFTId", ParentMFTId,
                                "ParentSequence", ParentSequence,
                                "Usn", Usn,
                                "Reason", Reason,
                                "FileAttributes", FileAttributes,
                                "SourceInfo", SourceInfo,
                                "Links", Links
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [FileSystem] WindowsForensicsRecycleBin — Deleted files
    let _recycleBin =
        WindowsForensicsRecycleBin
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "FileSystem" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "RecycleBinDelete" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "FileSystem",
            EventType      = "RecycleBinDelete",
            Description    = strcat("[RecycleBin] Deleted | ", coalesce(OriginalFilePath, ""), " | Size: ", tostring(FileSize)),
            User           = "",
            Path           = coalesce(OriginalFilePath, ""),
            Hash           = "",
            Details        = bag_pack(
                                "OriginalFilePath", OriginalFilePath,
                                "RecyclePath", RecyclePath,
                                "OSPath", OSPath,
                                "Name", Name,
                                "FileSize", FileSize
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [FileSystem] WindowsAnalysisEvidenceOfDownload — Downloaded files (Zone.Identifier)
    let _evidenceOfDownload =
        WindowsAnalysisEvidenceOfDownload
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "FileSystem" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "Download" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "FileSystem",
            EventType      = "Download",
            Description    = strcat("[ZoneId] Download | ", coalesce(DownloadedFilePath, ""), " | URL: ", coalesce(HostUrl, "")),
            User           = "",
            Path           = coalesce(DownloadedFilePath, ""),
            Hash           = coalesce(FileHashSHA256, FileHashSHA1, FileHashMD5, ""),
            Details        = bag_pack(
                                "HostUrl", HostUrl,
                                "ReferrerUrl", ReferrerUrl,
                                "ZoneId", ZoneId,
                                "ZoneIdentifierContent", ZoneIdentifierContent
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // ========================================================================
    // EventLogs / Detections
    // ========================================================================
    // [EventLog] WindowsHayabusaRules — Sigma/Hayabusa detection rules
    let _hayabusaRules =
        WindowsHayabusaRules
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "EventLog" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "HayabusaAlert" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "EventLog",
            EventType      = "HayabusaAlert",
            Description    = strcat("[", Channel, "] ", Title, " | EID: ", tostring(EID), " | Level: ", coalesce(Level, "")),
            User           = "",
            Path           = "",
            Hash           = "",
            Details        = bag_pack(
                                "Title", Title,
                                "Level", Level,
                                "EID", EID,
                                "Channel", Channel,
                                "Computer", Computer,
                                "RecordID", RecordID,
                                "Details", Details,
                                "Source", Source,
                                "Event", Event,
                                "Enrichment", Enrichment
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [EventLog] WindowsEventLogsEvtx — Raw Windows event logs
    let _evtx =
        WindowsEventLogsEvtx
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "EventLog" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "EvtxEvent" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "EventLog",
            EventType      = "EvtxEvent",
            Description    = strcat("[", Channel, "] ", coalesce(Provider, ""), " | EID: ", tostring(EventID), " | ", replace_string(replace_string(coalesce(Message, ""), "\n", " "), "\r", "")),
            User           = "",
            Path           = coalesce(OSPath, ""),
            Hash           = "",
            Details        = bag_pack(
                                "EventID", EventID,
                                "Channel", Channel,
                                "Provider", Provider,
                                "Level", Level,
                                "Computer", Computer,
                                "RecordID", EventRecordID,
                                "EventData", EventData,
                                "Keywords", Keywords,
                                "Message", Message
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
    // [EventLog] WindowsEventLogsHayabusaResults — Hayabusa parsed results
    let _hayabusaResults =
        WindowsEventLogsHayabusaResults
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "EventLog" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "HayabusaResult" in (_fTypeList)
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "EventLog",
            EventType      = "HayabusaResult",
            Description    = strcat("[", Channel, "] ", RuleTitle, " | EID: ", tostring(EventID), " | Level: ", coalesce(Level, ""), " | ", substring(coalesce(Details, ""), 0, 120), iff(strlen(Details) > 120, "...", "")),
            User           = trim_end(@"\s", extract(@"User: ([^¦]+)", 1, coalesce(Details, ""))),
            Path           = trim_end(@"\s", extract(@"Proc: ([^¦]+)", 1, coalesce(Details, ""))),
            Hash           = "",
            Details        = bag_pack(
                                "RuleTitle", RuleTitle,
                                "RuleID", RuleID,
                                "Level", Level,
                                "EventID", EventID,
                                "Channel", Channel,
                                "Computer", Computer,
                                "RecordID", RecordID,
                                "Details", Details,
                                "ExtraFieldInfo", ExtraFieldInfo
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
