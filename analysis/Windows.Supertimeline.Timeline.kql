    // [Detection] WindowsDetectionMalfind — Injected code / suspicious memory sections
    let _malfind =
        WindowsDetectionMalfind
        | where Timestamp between (_start .. _end)
        | where isempty(_host) or Hostname has _host
        | where isempty(_org) or Organization == _org
        | where array_length(_fCategoryList) == 0 or "Detection" in (_fCategoryList)
        | where array_length(_fTypeList)     == 0 or "Malfind" in (_fTypeList)
        | extend _lastProc = ProcessChain[array_length(ProcessChain)-1]
        | mv-apply _p = ProcessChain on (
            summarize _chainList = make_list(strcat(replace_regex(tostring(_p.Exe), @"^.*\\", ""), ":", tostring(_p.Pid)))
        )
        | extend _chainStr = strcat_array(_chainList, " -> ")
        | project
            EventTime      = Timestamp,
            Hostname,
            EventCategory  = "Detection",
            EventType      = "Malfind",
            Description    = strcat("[Malfind] Injection | ", Name, " (PID: ", tostring(Pid), ") | ", _chainStr, " | Yara: ", coalesce(YaraRule, "none")),
            User           = coalesce(tostring(_lastProc.Username), ""),
            Path           = coalesce(tostring(_lastProc.Exe), PathSpec, ""),
            Hash           = "",
            Details        = bag_pack(
                                "Name", Name,
                                "Pid", Pid,
                                "CreateTime", CreateTime,
                                "Address", Address,
                                "AddressRange", AddressRange,
                                "Protection", Protection,
                                "SectionSize", SectionSize,
                                "DataMagic", DataMagic,
                                "YaraRule", YaraRule,
                                "YaraStringName", YaraStringName,
                                "YaraStringData", YaraStringData,
                                "ProcessChain", ProcessChain
                            ),
            SourceArtifact = Artifact,
            Organization,
            ClientId,
            FlowId,
            IngestionTime;
